#include <stdio.h>

int main() {
    int a[10],pos,value, n=8;
    printf("Enter the Element In Array");
    for(int i=0;i<n;i++){
        scanf("%d", &a[i]);
    }
    printf("Enter The Value Which You Want To Insert");
    scanf("%d",&value);
    printf("Enter the position where you want to enter");
    scanf("%d",&pos);
    
    for(int i=n; i>pos; i--){
        a[i]=a[i-1];
    }
    a[pos-1]=value;
    n++;
    printf("Array after The Insertion Of Element");
        for(int i=0;i<10;i++){
            printf("%d",a[i]);
        }
        return 0;
}
